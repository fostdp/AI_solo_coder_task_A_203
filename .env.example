# ============================================================
#  宋代筒车水润滑轴承系统 — 环境变量模板
# ============================================================

# ---------- InfluxDB v2 ----------
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=s3cr3t-t0k3n-f0r-b34r1ng
INFLUXDB_ORG=water-bearing
INFLUXDB_BUCKET=bearing_sensor
INFLUXDB_PASSWORD=Admin123!

# ---------- FastAPI / Gunicorn ----------
HOST=0.0.0.0
PORT=8000
GUNICORN_WORKERS=4
LOG_LEVEL=info

# ---------- 告警阈值 ----------
MAX_POWER_LOSS_W=500
RUPTURE_RISK_THRESHOLD=0.7
CAVITATION_THRESHOLD=0.3

# ---------- 模拟器 (BearingSimulator) ----------
# 可选轴承ID: bearing-south-01, bearing-north-02, bearing-central-03
BEARING_ID=bearing-south-01

# 转速 (RPM): 宋代筒车典型 10~60
SIM_BASE_RPM=30.0
SIM_RPM_AMPLITUDE=8.0

# 水质: clean | sediment(含沙) | salty(咸水) | corrosive(腐蚀)
SIM_WATER_QUALITY=clean

# 进水温度 (摄氏度)
SIM_BASE_TEMP_C=20.0

# 推送间隔秒数
SIM_INTERVAL_SEC=5.0

# 载荷系数 0~2 (0.5 额定载荷一半)
SIM_LOAD_FACTOR=0.5

# 故障注入: none | cavitation | wear | dry_run | overload
SIM_INJECT_FAULT=none
